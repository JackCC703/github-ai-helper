{
  "name": "my-github-ai-helper",
  "displayName": "My github ai helper",
  "version": "0.0.1",
  "description": "A browser extension that generates GitHub PR descriptions from diffs using Kimi.",
  "author": "JackCC <chencan0703@gmail.com>",
  "scripts": {
    "dev": "plasmo dev",
    "build": "plasmo build",
    "package": "plasmo package"
  },
  "dependencies": {
    "plasmo": "0.90.5",
    "react": "18.2.0",
    "react-dom": "18.2.0"
  },
  "devDependencies": {
    "@ianvs/prettier-plugin-sort-imports": "4.1.1",
    "@types/chrome": "0.0.258",
    "@types/node": "20.11.5",
    "@types/react": "18.2.48",
    "@types/react-dom": "18.2.18",
    "prettier": "3.2.4",
    "typescript": "5.3.3"
  },
  "manifest": {
    "permissions": [
      "tabs",
      "storage",
      "scripting"
    ],
    "host_permissions": [
      "https://github.com/*",
      "https://patch-diff.githubusercontent.com/*"
    ]
  }
}
